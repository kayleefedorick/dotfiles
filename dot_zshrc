# Show user/host name
export SHOW_USER=true
if [[ "$SHOW_USER" == "true" ]]; then
  RPROMPT="%F{cyan}(%F{yellow}%n%F{cyan}@%F{green}%m%F{cyan})"
fi

# If you come from bash you might have to change your $PATH.
export PATH=$HOME/bin:$HOME/.local/bin:/usr/local/bin:$HOME/.cargo/bin::$PATH

# Path to your Oh My Zsh installation.
export ZSH="$HOME/.oh-my-zsh"

# Editor
export EDITOR="/usr/bin/micro"
export VISUAL="$EDITOR"

# Themes
ZSH_THEME="robbyrussell"

# Plugins
plugins=(
	git
	command-not-found
	copyfile
	copypath
	history-substring-search
	zsh-bat
	extract
	sudo
	zsh-syntax-highlighting
	zsh-autosuggestions
)

source $ZSH/oh-my-zsh.sh

# Aliases
alias upgrade='cd $HOME/Developer/ansible-for-fedora-workstation/ && \
               git pull && ansible-playbook playbook.yml --ask-become-pass'
alias update='chezmoi update'

alias ls='eza --icons'
alias tree='eza -la --icons --tree --total-size --hyperlink'

alias nkxtract='/home/kaylee/Developer/nkxtract/nkxtract/bin/Release/net8.0/nkxtract'

# Claude
alias claude-default='source /home/kaylee/.rmlmstudio && claude --model claude-sonnet-4.6'
alias claude-local='source /home/kaylee/.lmstudio && claude --model omnicoder-qwen3.5-9b-claude-4.6-opus-uncensored-v2'

# Environment
export BAT_THEME="Dracula"

# opencode
export PATH=/home/kaylee/.opencode/bin:$PATH
